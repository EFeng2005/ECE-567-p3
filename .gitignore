.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Experiment artifacts
wandb/
outputs/
logs/
checkpoints/
tmp/
ogbench-*.out
ogbench-train-*.out
monitor.log
monitor_nohup.out

# Live symlinks to WSL output dirs (content lives on WSL Linux FS;
# CSV/flags.json are copied into results/ for git tracking, .pkl stays on WSL)
runs_wsl_*/

# Local data
data/
datasets/
scratch/

# Internal / temporary docs
docs/
skills.md

# Claude Code config
.claude/

# Preserved upstream OGBench .git (renamed out of external/ogbench/)
external/.ogbench-upstream-git/

# Upstream OGBench is re-fetched via scripts/bootstrap_ogbench.sh.
# Only our patched files are tracked; everything else is ignored.
external/ogbench/*
!external/ogbench/impls
external/ogbench/impls/*
!external/ogbench/impls/main.py
!external/ogbench/impls/agents
!external/ogbench/impls/utils
external/ogbench/impls/agents/*
!external/ogbench/impls/agents/__init__.py
!external/ogbench/impls/agents/chiql.py
!external/ogbench/impls/agents/ex_chiql.py
external/ogbench/impls/utils/*
!external/ogbench/impls/utils/env_utils.py
!external/ogbench/impls/utils/networks.py
